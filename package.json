{
  "name": "system-vis",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:sim",
    "dev:sim": "tsx watch src/index.ts",
    "build": "npm run build --workspace=@system-vis/shared && tsc -p tsconfig.json",
    "typecheck": "npm run typecheck --workspace=@system-vis/shared && tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.12.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@system-vis/shared": "*",
    "express": "^4.18.2",
    "groq-sdk": "^1.1.1",
    "socket.io": "^4.8.1"
  }
}
